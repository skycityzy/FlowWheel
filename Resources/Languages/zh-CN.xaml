    <s:String x:Key="LabelInertia">惯性大小</s:String>
    <s:String x:Key="DescInertia">释放后的初始惯性速度乘数</s:String>
    <s:String x:Key="LabelResponseTime">响应时间</s:String>
    <s:String x:Key="DescResponseTime">滚动速度变化的平滑过渡时间</s:String>
    <s:String x:Key="LabelAxisLock">轴锁定比例</s:String>
    <s:String x:Key="DescAxisLock">当某一方向移动距离超过另一方向此比例时，锁定另一方向</s:String>
    <s:String x:Key="LabelSoftStart">软启动范围</s:String>
    <s:String x:Key="DescSoftStart">在死区边缘的平滑过渡区域，避免突然启动</s:String>
    <s:String x:Key="LabelMaxScrollSpeed">最大滚动速度</s:String>
    <s:String x:Key="DescMaxScrollSpeed">拖拽滚动时的速度上限，值越大最大速度越快</s:String>

