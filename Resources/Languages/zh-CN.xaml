    <s:String x:Key="SectionAccelerationCurve">加速度曲线</s:String>
    <s:String x:Key="LabelCurveType">曲线类型</s:String>
    <s:String x:Key="CurveLinear">线性</s:String>
    <s:String x:Key="CurveExponential">指数</s:String>
    <s:String x:Key="CurveLogarithmic">对数</s:String>
