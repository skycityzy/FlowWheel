    <s:String x:Key="TraySettings">设置</s:String>
    <s:String x:Key="TrayToggle">开启/暂停 自动滚屏</s:String>
    <s:String x:Key="TrayExit">退出</s:String>
    <s:String x:Key="TrayRunning">FlowWheel (运行中)</s:String>
    <s:String x:Key="TrayPaused">FlowWheel (已暂停)</s:String>

    <s:String x:Key="BtnCheckUpdate">检查更新</s:String>
    <s:String x:Key="BtnLicense">许可证</s:String>
    <s:String x:Key="AppDescription">为 Windows 带来流畅的浏览器风格中键自动滚动，支持惯性和多屏同步。</s:String>
