    <s:String x:Key="DescEnable">开启或关闭自动滚屏功能</s:String>
    <s:String x:Key="CheckStartup">开机自启动</s:String>
    <s:String x:Key="DescStartup">系统启动时自动运行 FlowWheel</s:String>
    <s:String x:Key="CheckSyncScroll">多屏/分屏 同步滚动</s:String>
