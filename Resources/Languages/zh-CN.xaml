    <s:String x:Key="LabelIndependentSensitivity">独立灵敏度</s:String>
    <s:String x:Key="DescIndependentSensitivity">分别设置垂直和水平方向的滚动灵敏度</s:String>
    <s:String x:Key="LabelVerticalSpeed">垂直速度</s:String>
    <s:String x:Key="LabelHorizontalSpeed">水平速度</s:String>
    
    <!-- Reading Mode -->
    <s:String x:Key="SectionReadingMode">阅读模式</s:String>
    <s:String x:Key="LabelReadingSpeed">初始速度</s:String>
    <s:String x:Key="LabelReadingMaxSpeed">最大速度</s:String>
    
