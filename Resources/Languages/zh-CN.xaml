<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">
    <s:String x:Key="WindowTitle">FlowWheel 设置</s:String>
    <s:String x:Key="AppName">FlowWheel</s:String>
    
    <!-- Navigation -->
    <s:String x:Key="NavGeneral">常规</s:String>
    <s:String x:Key="NavBehavior">行为</s:String>
    <s:String x:Key="NavFilter">应用过滤</s:String>
    <s:String x:Key="NavShortcuts">快捷键</s:String>
    <s:String x:Key="NavAbout">关于</s:String>
    
    <!-- Sections -->
    <s:String x:Key="SectionLanguage">语言</s:String>
    <s:String x:Key="SectionStatus">状态</s:String>
    <s:String x:Key="SectionPerformance">性能</s:String>
    <s:String x:Key="SectionTrigger">触发选项</s:String>
    <s:String x:Key="SectionTriggerMode">触发模式</s:String>
    <s:String x:Key="SectionTriggerKey">触发按键</s:String>
    <s:String x:Key="SectionSensitivity">灵敏度</s:String>
    <s:String x:Key="SectionCustomIcon">自定义图标</s:String>
    <s:String x:Key="LabelCustomIcon">自定义图标路径</s:String>
    <s:String x:Key="DescCustomIcon">选择 PNG/JPG 图片作为滚动图标</s:String>
    <s:String x:Key="LabelIconSize">图标大小</s:String>
    <s:String x:Key="DescIconSize">调整滚动图标的大小 (24-96 像素)</s:String>
