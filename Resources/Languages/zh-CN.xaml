    <s:String x:Key="LabelLanguage">语言</s:String>
    <s:String x:Key="LabelPerformanceMode">性能模式</s:String>
    <s:String x:Key="DescPerformanceMode">省电模式后台占用最低，高性能模式最流畅</s:String>
    <s:String x:Key="PerfPowerSaver">省电模式 (30Hz)</s:String>
    <s:String x:Key="PerfBalanced">平衡模式 (60Hz)</s:String>
    <s:String x:Key="PerfHighPerf">高性能模式 (120Hz)</s:String>
