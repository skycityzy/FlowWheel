    <s:String x:Key="ListenSuccess">Trigger key set to: </s:String>
    <s:String x:Key="KeyMiddleMouse">Middle Mouse Button</s:String>
    <s:String x:Key="KeyXButton1">Mouse Side Button 1 (Back)</s:String>
    <s:String x:Key="KeyXButton2">Mouse Side Button 2 (Forward)</s:String>
    <s:String x:Key="RadioClickToggle">Click Toggle (Recommended)</s:String>
    <s:String x:Key="RadioHoldDrag">Hold &amp; Drag</s:String>
    
    <s:String x:Key="LabelScrollSpeed">Scroll Speed</s:String>
    <s:String x:Key="LabelDeadzone">Deadzone (Radius)</s:String>
    <s:String x:Key="DescDeadzone">Area where movement is ignored</s:String>
    
