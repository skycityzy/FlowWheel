<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Colors -->
    <Color x:Key="Color.Accent">#007ACC</Color>
    <SolidColorBrush x:Key="Brush.Background" Color="#F5F5F7"/>
    <SolidColorBrush x:Key="Brush.Card.Background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#666680"/>
    <SolidColorBrush x:Key="Brush.Border" Color="#E0E0E8"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.Sidebar.Background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Hover" Color="#F0F0F5"/>
    <SolidColorBrush x:Key="Brush.Pressed" Color="#E8E8F0"/>
    <SolidColorBrush x:Key="Brush.Control.Background" Color="#F8F8FA"/>
    <SolidColorBrush x:Key="Brush.Control.Border" Color="#D0D0DC"/>
    <SolidColorBrush x:Key="Brush.Input.Background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.ListBox.Item.Hover" Color="#F0F0F5"/>
    <SolidColorBrush x:Key="Brush.ListBox.Item.Selected" Color="#E8E8F5"/>

    <!-- Curve Control Colors -->
    <SolidColorBrush x:Key="Brush.Curve.Background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Curve.Grid" Color="#E0E0E8"/>
    <SolidColorBrush x:Key="Brush.Curve.Axis" Color="#808090"/>
    <SolidColorBrush x:Key="Brush.Curve.Label" Color="#666680"/>
    <SolidColorBrush x:Key="Brush.Curve.Diagonal" Color="#D0D0DC"/>
    <SolidColorBrush x:Key="Brush.Curve.Line" Color="#007ACC"/>
    <SolidColorBrush x:Key="Brush.Curve.Point" Color="#007ACC"/>
    <SolidColorBrush x:Key="Brush.Curve.PointFill" Color="#FFFFFF"/>

    <!-- Overlay-specific colors (derived from Accent) -->
    <SolidColorBrush x:Key="Brush.Overlay.Ring" Color="#007ACC"/>
    <SolidColorBrush x:Key="Brush.Overlay.Glow" Color="#007ACC"/>
</ResourceDictionary>
