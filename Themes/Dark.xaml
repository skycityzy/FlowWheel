<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors -->
    <Color x:Key="Color.Accent">#4DA6FF</Color>
    <SolidColorBrush x:Key="Brush.Background" Color="#16161E"/>
    <SolidColorBrush x:Key="Brush.Card.Background" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#B0B0C0"/>
    <SolidColorBrush x:Key="Brush.Border" Color="#3A3A4A"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.Sidebar.Background" Color="#1A1A28"/>
    <SolidColorBrush x:Key="Brush.Hover" Color="#2A2A3A"/>
    <SolidColorBrush x:Key="Brush.Pressed" Color="#353550"/>
    <SolidColorBrush x:Key="Brush.Control.Background" Color="#252535"/>
    <SolidColorBrush x:Key="Brush.Control.Border" Color="#404055"/>
    <SolidColorBrush x:Key="Brush.Input.Background" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="Brush.ListBox.Item.Hover" Color="#2A2A3E"/>
    <SolidColorBrush x:Key="Brush.ListBox.Item.Selected" Color="#353555"/>
    
    <!-- Curve Control Colors -->
    <SolidColorBrush x:Key="Brush.Curve.Background" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="Brush.Curve.Grid" Color="#3A3A4A"/>
    <SolidColorBrush x:Key="Brush.Curve.Axis" Color="#808090"/>
    <SolidColorBrush x:Key="Brush.Curve.Label" Color="#A0A0B0"/>
    <SolidColorBrush x:Key="Brush.Curve.Diagonal" Color="#505060"/>
    <SolidColorBrush x:Key="Brush.Curve.Line" Color="#4DA6FF"/>
    <SolidColorBrush x:Key="Brush.Curve.Point" Color="#4DA6FF"/>
    <SolidColorBrush x:Key="Brush.Curve.PointFill" Color="#1E1E2E"/>
    
    <!-- Overlay-specific colors (derived from Accent) -->
    <SolidColorBrush x:Key="Brush.Overlay.Ring" Color="#4DA6FF"/>
    <SolidColorBrush x:Key="Brush.Overlay.Glow" Color="#4DA6FF"/>
</ResourceDictionary>