                                    <Path x:Name="star2" Canvas.Left="34" Canvas.Top="7" Width="5" Height="5" Fill="White"/>
                                    <Path Canvas.Left="22" Canvas.Top="9" Width="2.5" Height="2.5" Fill="White"/>
                                    <Path Canvas.Left="16" Canvas.Top="12" Width="2.5" Height="2.5" Fill="White"/>
                                    <Path Canvas.Left="24" Canvas.Top="16" Width="2.5" Height="2.5" Fill="White"/>
                                    <Path Canvas.Left="33" Canvas.Top="15" Width="2.5" Height="2.5" Fill="White"/>
                                    <Path Canvas.Left="27" Canvas.Top="5" Width="2.5" Height="2.5" Fill="White"/>
                                    <Path x:Name="star4" Canvas.Left="7" Canvas.Top="7" Width="2.5" Height="2.5" Fill="White"/>
                                </Canvas>
                                
                                <!-- Clouds -->
                                <Path x:Name="cloud1" Margin="1,2,0,0" Width="60" Height="24"
                                      Data="{StaticResource CloudGeometry1}"
                                      Fill="#88FFFFFF" Stretch="UniformToFill" Opacity="0.7">
                                    <Path.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                                <Path x:Name="cloud2" Margin="1,6,0,0" Width="60" Height="20"
                                      Data="{StaticResource CloudGeometry2}"
                                      Fill="White" Stretch="UniformToFill" Opacity="0.9">
                                    <Path.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Path.RenderTransform>
                                </Path>
                                
                                <!-- Glow Effects -->
                                <Rectangle x:Name="glow1" Width="55" Height="55" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                           Fill="#11FFFFFF" RadiusX="28" RadiusY="28" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform X="0"/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <Rectangle x:Name="glow2" Width="47" Height="47" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                           Fill="#22FFFFFF" RadiusX="24" RadiusY="24" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform X="0"/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <Rectangle x:Name="glow3" Width="39" Height="39" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                           Fill="#22FFFFFF" RadiusX="20" RadiusY="20" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <TranslateTransform X="0"/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                
                                <!-- Thumb (Sun/Moon) -->
                                <Border x:Name="thumb" Width="24" Height="24" HorizontalAlignment="Left" CornerRadius="12" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="0"/>
                                            <TranslateTransform X="3"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Canvas>
                                        <Rectangle Canvas.Top="2" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Bottom" RadiusX="12" RadiusY="12">
                                            <Rectangle.Fill>
                                                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                                    <GradientStop Offset="1" Color="#00000000"/>
                                                    <GradientStop Offset="0.7" Color="#E5000000"/>
                                                </RadialGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Grid x:Name="sun" Canvas.Top="2" Width="22" Height="22" HorizontalAlignment="Left" Background="#F3C62B" RenderTransformOrigin="0.5,0.5">
                                            <Grid.RenderTransform>
                                                <TransformGroup>
                                                    <RotateTransform Angle="0"/>
                                                </TransformGroup>
                                            </Grid.RenderTransform>
                                            <Grid.Clip>
                                                <RectangleGeometry RadiusX="11" RadiusY="11" Rect="0,0,22,22"/>
                                            </Grid.Clip>
                                            <!-- Sun Highlight -->
                                            <Path Width="18" Margin="-1,-1,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                  Data="M195.79568,256.36186 C128.27033,194.80746 208.6956,103.20326 276.96226,155.20326 220.40909,129.80395 148.71988,171.59981 195.79568,256.36186 z"
                                                  Stretch="Uniform" Visibility="Visible">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.3,1">
                                                        <GradientStop Offset="0" Color="Transparent"/>
                                                        <GradientStop Offset="0.1" Color="White"/>
                                                        <GradientStop Offset="1" Color="Transparent"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                            </Path>
                                            <!-- Sun Highlight Mask -->
                                            <Ellipse x:Name="highlightMask" Opacity="0">
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6FFFFFFF"/>
                                                        <GradientStop Offset="1" Color="Transparent"/>
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <!-- Moon -->
                                            <Border x:Name="moon">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="3" RenderingBias="Performance" ShadowDepth="1" Color="Gray"/>
                                                </Border.Effect>
                                                <Border.RenderTransform>
                                                    <TransformGroup>
                                                        <TranslateTransform X="26"/>
                                                    </TransformGroup>
                                                </Border.RenderTransform>
                                                <Grid>
                                                    <Grid.Clip>
                                                        <RectangleGeometry RadiusX="11" RadiusY="11" Rect="0,0,22,22"/>
                                                    </Grid.Clip>
                                                    <Rectangle Fill="#C4C9D4"/>
                                                    <Border Width="7" Height="7" Margin="4,9,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#9A9FB2"
                                                            BorderBrush="#66000000" BorderThickness="0.5" CornerRadius="4"/>
                                                    <Border Width="4" Height="4" Margin="9,3,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#9A9FB2"
                                                            BorderBrush="#66000000" BorderThickness="0.5" CornerRadius="3"/>
                                                    <Border Width="5" Height="5" Margin="14,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#9A9FB2"
                                                            BorderBrush="#66000000" BorderThickness="0.5" CornerRadius="3"/>
                                                    <!-- Moon Highlight -->
                                                    <Path Width="18" Margin="-1,-1,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                          Data="M195.79568,256.36186 C128.27033,194.80746 208.6956,103.20326 276.96226,155.20326 220.40909,129.80395 148.71988,171.59981 195.79568,256.36186 z"
                                                          Stretch="Uniform" Visibility="Visible">
                                                        <Path.Fill>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                <GradientStop Offset="0" Color="Transparent"/>
                                                                <GradientStop Offset="0.2" Color="#DDFFFFFF"/>
                                                                <GradientStop Offset="1" Color="Transparent"/>
                                                            </LinearGradientBrush>
                                                        </Path.Fill>
                                                    </Path>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Canvas>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard Storyboard="{StaticResource ThumbMouseHover}"/>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard Storyboard="{StaticResource ThumbMouseLeave}"/>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                                
                                <!-- Shadow -->
                                <Border Margin="-1,-1" BorderBrush="#5C6170" BorderThickness="1.2" CornerRadius="14" RenderTransformOrigin="0.5,0.5">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" RenderingBias="Performance" ShadowDepth="0"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                            <Border.Clip>
                                <RectangleGeometry RadiusX="14" RadiusY="14" Rect="0,0,70,28"/>
                            </Border.Clip>
                        </Border>
                    </Viewbox>
                    <!-- Transparent hit area for click detection -->
                    <Border x:Name="PART_SwitchTrack" Background="Transparent" CornerRadius="14"/>
                </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsOn" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource StoryboardChecked}"/>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource StoryboardUnChecked}"/>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CurveEditor Control -->
    <Style TargetType="{x:Type controls:CurveEditor}">
        <Setter Property="Width" Value="300"/>
        <Setter Property="Height" Value="200"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Input.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Control.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CurveEditor}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            ClipToBounds="False">
                        <Canvas x:Name="PART_Canvas" Margin="4" Background="Transparent" ClipToBounds="False"
                                IsHitTestVisible="True">
                            <Path x:Name="PART_CurvePath" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2"
                                  IsHitTestVisible="False"/>
                         </Canvas>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>