                                    <Grid Style="{StaticResource SettingRow}" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LabelSigmoidSteepness}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock x:Name="SigmoidSteepnessValueText" Text="8.0" Grid.Column="1" 
