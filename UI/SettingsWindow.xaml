                                <StackPanel x:Name="SigmoidParamsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LabelSigmoidMidpoint}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock x:Name="SigmoidMidpointValueText" Text="0.5" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="SigmoidMidpointSlider" Minimum="0.1" Maximum="0.9" Value="0.5" 
                                            TickFrequency="0.05" IsSnapToTickEnabled="True" 
