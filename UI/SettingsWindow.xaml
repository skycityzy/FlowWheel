<Window x:Class="FlowWheel.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowWheel.UI.Controls"
        Title="{DynamicResource WindowTitle}" 
        Height="580" Width="780"
        ResizeMode="CanResize" 
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background}" FontFamily="Segoe UI"
        x:Name="MainWindow">
    
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Background Decoration Layer -->
        <Canvas x:Name="DecorationCanvas" Grid.ColumnSpan="2" IsHitTestVisible="False" ClipToBounds="True">
            <!-- Stars for Dark Mode - More stars scattered across the background -->
            <Canvas x:Name="StarsCanvas" Opacity="0">
                <Canvas.Resources>
                    <Style TargetType="Path">
                        <Setter Property="Data" Value="M100,50 C72.38589,50 50,72.38589 50,100 C50,72.38589 27.61411,50 0,50 C27.61411,50 50,27.61411 50,0 C50,27.61411 72.38589,50 100,50 z"/>
                        <Setter Property="Stretch" Value="UniformToFill"/>
                        <Setter Property="Fill" Value="White"/>
                    </Style>
                </Canvas.Resources>
                <!-- Row 1 - Top area -->
                <Path x:Name="DecoStar1" Width="3" Height="3" Canvas.Left="80" Canvas.Top="25" Opacity="0.5"/>
                <Path x:Name="DecoStar2" Width="4" Height="4" Canvas.Left="200" Canvas.Top="35" Opacity="0.7"/>
                <Path x:Name="DecoStar3" Width="2" Height="2" Canvas.Left="350" Canvas.Top="20" Opacity="0.4"/>
                <Path x:Name="DecoStar4" Width="3" Height="3" Canvas.Left="500" Canvas.Top="45" Opacity="0.6"/>
                <Path x:Name="DecoStar5" Width="4" Height="4" Canvas.Left="650" Canvas.Top="30" Opacity="0.5"/>
                <!-- Row 2 - Middle area -->
                <Path x:Name="DecoStar6" Width="3" Height="3" Canvas.Left="120" Canvas.Top="100" Opacity="0.5"/>
                <Path x:Name="DecoStar7" Width="5" Height="5" Canvas.Left="280" Canvas.Top="120" Opacity="0.8"/>
                <Path x:Name="DecoStar8" Width="2" Height="2" Canvas.Left="420" Canvas.Top="95" Opacity="0.4"/>
                <Path x:Name="DecoStar9" Width="4" Height="4" Canvas.Left="550" Canvas.Top="130" Opacity="0.6"/>
                <Path x:Name="DecoStar10" Width="3" Height="3" Canvas.Left="700" Canvas.Top="110" Opacity="0.5"/>
                <!-- Row 3 - Lower middle -->
                <Path x:Name="DecoStar11" Width="3" Height="3" Canvas.Left="50" Canvas.Top="200" Opacity="0.6"/>
                <Path x:Name="DecoStar12" Width="4" Height="4" Canvas.Left="180" Canvas.Top="220" Opacity="0.7"/>
                <Path x:Name="DecoStar13" Width="2" Height="2" Canvas.Left="320" Canvas.Top="190" Opacity="0.4"/>
                <Path x:Name="DecoStar14" Width="3" Height="3" Canvas.Left="480" Canvas.Top="210" Opacity="0.5"/>
                <Path x:Name="DecoStar15" Width="4" Height="4" Canvas.Left="620" Canvas.Top="195" Opacity="0.6"/>
                <!-- Row 4 - Bottom area -->
                <Path x:Name="DecoStar16" Width="2" Height="2" Canvas.Left="100" Canvas.Top="300" Opacity="0.4"/>
                <Path x:Name="DecoStar17" Width="3" Height="3" Canvas.Left="250" Canvas.Top="320" Opacity="0.5"/>
                <Path x:Name="DecoStar18" Width="4" Height="4" Canvas.Left="400" Canvas.Top="290" Opacity="0.6"/>
                <Path x:Name="DecoStar19" Width="3" Height="3" Canvas.Left="580" Canvas.Top="310" Opacity="0.5"/>
                <Path x:Name="DecoStar20" Width="2" Height="2" Canvas.Left="720" Canvas.Top="285" Opacity="0.4"/>
                <!-- Extra twinkling stars -->
                <Path x:Name="DecoStar21" Width="5" Height="5" Canvas.Left="150" Canvas.Top="60" Opacity="0.9"/>
                <Path x:Name="DecoStar22" Width="5" Height="5" Canvas.Left="450" Canvas.Top="160" Opacity="0.85"/>
                <Path x:Name="DecoStar23" Width="5" Height="5" Canvas.Left="600" Canvas.Top="250" Opacity="0.9"/>
            </Canvas>
            
            <!-- Clouds for Light Mode - More clouds at different positions -->
            <Canvas x:Name="CloudsCanvas" Opacity="0">
                <!-- Bottom clouds -->
                <Path x:Name="Cloud1" Data="M158.99223,453.55724 C169.78284,423.31232 203.15378,392.41965 241.59875,404.12313 261.99875,383.72313 299.3,391.57463 305.3,392.77701 330.15525,362.39707 353.16314,370.00505 368.58869,378.91567 370.80287,377.8725 376.53823,377.01298 381.06677,376.82559 387.43795,354.90123 410.63981,354.27147 420.4351,355.75324 432.85079,341.48144 440.27525,342.83843 451.87985,342.32945 457.75133,307.27233 472.82215,288.94564 509.06064,292.16184 512.31051,292.45027 525.93938,292.61638 525.93938,292.61638 525.90428,295.34879 526.73875,460.86787 526.8053,465.68179 L154.99571,465.6552 z"
                      Fill="#77FFFFFF" Stretch="UniformToFill" Width="180" Height="50" Canvas.Left="-30" Canvas.Bottom="-10" Opacity="0.95"/>
                <Path x:Name="Cloud2" Data="M158.99223,453.55724 C169.78284,423.31232 203.15378,392.41965 241.59875,404.12313 261.99875,383.72313 299.3,391.57463 305.3,392.77701 337.22357,353.75764 390.50003,373.43798 398.90003,384.97667 412.50003,378.21261 430.04088,381.41688 430.04088,381.41688 436.82018,362.13027 456.18064,352.96024 465.00342,351.59457 460.57167,304.02021 510.55723,292.35177 521.33687,292.25901 530.92623,292.1765 525.93938,292.61638 525.93938,292.61638 525.90428,295.34879 526.73875,460.86787 526.8053,465.68179 L154.99571,465.6552 z"
                      Fill="#88FFFFFF" Stretch="UniformToFill" Width="200" Height="55" Canvas.Left="480" Canvas.Bottom="-5" Opacity="0.9"/>
                <Path x:Name="Cloud3" Data="M158.99223,453.55724 C169.78284,423.31232 203.15378,392.41965 241.59875,404.12313 261.99875,383.72313 299.3,391.57463 305.3,392.77701 330.15525,362.39707 353.16314,370.00505 368.58869,378.91567 370.80287,377.8725 376.53823,377.01298 381.06677,376.82559 387.43795,354.90123 410.63981,354.27147 420.4351,355.75324 432.85079,341.48144 440.27525,342.83843 451.87985,342.32945 457.75133,307.27233 472.82215,288.94564 509.06064,292.16184 512.31051,292.45027 525.93938,292.61638 525.93938,292.61638 525.90428,295.34879 526.73875,460.86787 526.8053,465.68179 L154.99571,465.6552 z"
                      Fill="#66FFFFFF" Stretch="UniformToFill" Width="150" Height="40" Canvas.Left="220" Canvas.Bottom="-8" Opacity="0.85"/>
                <!-- Middle clouds -->
                <Path x:Name="Cloud4" Data="M158.99223,453.55724 C169.78284,423.31232 203.15378,392.41965 241.59875,404.12313 261.99875,383.72313 299.3,391.57463 305.3,392.77701 330.15525,362.39707 353.16314,370.00505 368.58869,378.91567 370.80287,377.8725 376.53823,377.01298 381.06677,376.82559 387.43795,354.90123 410.63981,354.27147 420.4351,355.75324 432.85079,341.48144 440.27525,342.83843 451.87985,342.32945 457.75133,307.27233 472.82215,288.94564 509.06064,292.16184 512.31051,292.45027 525.93938,292.61638 525.93938,292.61638 525.90428,295.34879 526.73875,460.86787 526.8053,465.68179 L154.99571,465.6552 z"
                      Fill="#55FFFFFF" Stretch="UniformToFill" Width="120" Height="35" Canvas.Left="600" Canvas.Top="80" Opacity="0.7"/>
                <Path x:Name="Cloud5" Data="M158.99223,453.55724 C169.78284,423.31232 203.15378,392.41965 241.59875,404.12313 261.99875,383.72313 299.3,391.57463 305.3,392.77701 330.15525,362.39707 353.16314,370.00505 368.58869,378.91567 370.80287,377.8725 376.53823,377.01298 381.06677,376.82559 387.43795,354.90123 410.63981,354.27147 420.4351,355.75324 432.85079,341.48144 440.27525,342.83843 451.87985,342.32945 457.75133,307.27233 472.82215,288.94564 509.06064,292.16184 512.31051,292.45027 525.93938,292.61638 525.93938,292.61638 525.90428,295.34879 526.73875,460.86787 526.8053,465.68179 L154.99571,465.6552 z"
                      Fill="#44FFFFFF" Stretch="UniformToFill" Width="100" Height="30" Canvas.Left="350" Canvas.Top="50" Opacity="0.6"/>
                <Path x:Name="Cloud6" Data="M158.99223,453.55724 C169.78284,423.31232 203.15378,392.41965 241.59875,404.12313 261.99875,383.72313 299.3,391.57463 305.3,392.77701 330.15525,362.39707 353.16314,370.00505 368.58869,378.91567 370.80287,377.8725 376.53823,377.01298 381.06677,376.82559 387.43795,354.90123 410.63981,354.27147 420.4351,355.75324 432.85079,341.48144 440.27525,342.83843 451.87985,342.32945 457.75133,307.27233 472.82215,288.94564 509.06064,292.16184 512.31051,292.45027 525.93938,292.61638 525.93938,292.61638 525.90428,295.34879 526.73875,460.86787 526.8053,465.68179 L154.99571,465.6552 z"
                      Fill="#33FFFFFF" Stretch="UniformToFill" Width="80" Height="25" Canvas.Left="500" Canvas.Top="150" Opacity="0.5"/>
            </Canvas>
        </Canvas>
        
        <!-- Dark mode water drop animation overlay -->
        <Canvas x:Name="OverlayCanvas" Grid.ColumnSpan="2" IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse x:Name="WaterDrop" 
                     Width="0" Height="0"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="WaterDropTranslate" X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>
        
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="{DynamicResource Brush.Sidebar.Background}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Margin="16,16,16,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconFlowWheel}" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.2" Fill="{DynamicResource Brush.Accent}" Opacity="0.85"
                              Width="22" Height="22" Stretch="Uniform" Margin="0,0,8,0">
                            <Path.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.5" Color="{DynamicResource Color.Accent}"/>
                            </Path.Effect>
                        </Path>
                        <TextBlock Text="FlowWheel" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </StackPanel>
                    <TextBlock x:Name="VersionLabel" Text="v1.7.0" FontSize="11" 
                               Foreground="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Margin="8,4">
                    <RadioButton x:Name="NavGeneral" GroupName="Nav" Content="{DynamicResource NavGeneral}" 
                                 Tag="{StaticResource IconSettings}" IsChecked="True" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavBehavior" GroupName="Nav" Content="{DynamicResource NavBehavior}" 
                                 Tag="{StaticResource IconMouse}" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavFilter" GroupName="Nav" Content="{DynamicResource NavFilter}" 
                                 Tag="{StaticResource IconFilter}" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavShortcuts" GroupName="Nav" Content="{DynamicResource NavShortcuts}" 
                                 Tag="{StaticResource IconKeyboard}" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavAbout" GroupName="Nav" Content="{DynamicResource NavAbout}" 
                                 Tag="{StaticResource IconInfo}" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
                
                <Border Grid.Row="2" Margin="12,0,12,12" Background="{DynamicResource Brush.Control.Background}" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LabelDarkMode}" FontSize="12" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        </StackPanel>
                        <controls:ToggleSwitch x:Name="DarkModeToggle" Grid.Column="1" Style="{StaticResource GorgeousThemeToggleStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border x:Name="HeaderBorder" Grid.Row="0" Background="{DynamicResource Brush.Sidebar.Background}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="16,12">
                <TextBlock x:Name="PageTitle" Text="{DynamicResource NavGeneral}" 
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
            </Border>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                <Grid>
                    <StackPanel x:Name="PageGeneral" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionLanguage}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelLanguage}" Style="{StaticResource SettingLabel}"/>
                                    <ComboBox x:Name="LanguageCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}"
                                              Width="200" SelectionChanged="LanguageCombo_SelectionChanged">
                                        <ComboBoxItem Content="English" Tag="en-US"/>
                                        <ComboBoxItem Content="简体中文" Tag="zh-CN"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionPerformance}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelPerformanceMode}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescPerformanceMode}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="PerformanceModeCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}"
                                              Width="200" SelectionChanged="PerformanceModeCombo_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource PerfPowerSaver}" Tag="PowerSaver"/>
                                        <ComboBoxItem Content="{DynamicResource PerfBalanced}" Tag="Balanced"/>
                                        <ComboBoxItem Content="{DynamicResource PerfHighPerf}" Tag="HighPerformance"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionStatus}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckEnable}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescEnable}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="EnableToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckStartup}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescStartup}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="StartupToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageBehavior" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionTrigger}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckSyncScroll}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescSyncScroll}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="SyncToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckReadingMode}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescReadingMode}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="ReadingModeToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                                <TextBlock Text="{DynamicResource TipReadingModeSpeed}" 
                                           Style="{StaticResource SettingDescription}" 
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource Brush.Accent}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionTriggerMode}" Style="{StaticResource SectionTitle}"/>
                                
                                <RadioButton x:Name="RadioClickToggle" GroupName="TriggerMode" 
                                             Content="{DynamicResource RadioClickToggle}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                                
                                <RadioButton x:Name="RadioHoldDrag" GroupName="TriggerMode" 
                                             Content="{DynamicResource RadioHoldDrag}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionDelayStart}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelDelayStart}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescDelayStart}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="DelayStartToggle" Grid.Column="1" Width="44" Height="24"
                                                          IsOnChanged="DelayStartToggle_IsOnChanged"/>
                                </Grid>
                                
                                <StackPanel x:Name="DelaySliderPanel">
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LabelDelayValue}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock x:Name="MiddleClickDelayValueText" Text="150ms" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="MiddleClickDelaySlider" Minimum="50" Maximum="500" Value="150" 
                                            TickFrequency="10" IsSnapToTickEnabled="True" 
                                            ValueChanged="MiddleClickDelaySlider_ValueChanged"/>
                                    <TextBlock Text="{DynamicResource DescDelayValueNote}" Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionSensitivity}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelIndependentSensitivity}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescIndependentSensitivity}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="IndependentSensitivityToggle" Grid.Column="1" Width="44" Height="24" IsOnChanged="IndependentSensitivityToggle_IsOnChanged"/>
                                </Grid>
                                
                                <Grid Style="{StaticResource SettingRow}" x:Name="UnifiedSensitivityPanel">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelScrollSpeed}" Style="{StaticResource SettingLabel}"/>
                                    <TextBlock x:Name="SpeedValueText" Text="0.8x" Grid.Column="1" 
                                               Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                </Grid>
                                <Slider x:Name="SpeedSlider" Minimum="0.1" Maximum="3.0" Value="0.8" 
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                        ValueChanged="SpeedSlider_ValueChanged"/>
                                
                                <StackPanel x:Name="IndependentSensitivityPanel" Visibility="Collapsed">
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LabelVerticalSpeed}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock x:Name="VerticalSpeedValueText" Text="1.0x" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="VerticalSpeedSlider" Minimum="0.1" Maximum="5.0" Value="1.0" 
                                            TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                            ValueChanged="VerticalSpeedSlider_ValueChanged"/>
                                    
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LabelHorizontalSpeed}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock x:Name="HorizontalSpeedValueText" Text="0.8x" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="HorizontalSpeedSlider" Minimum="0.1" Maximum="5.0" Value="0.8" 
                                            TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                            ValueChanged="HorizontalSpeedSlider_ValueChanged"/>
                                </StackPanel>
                                
                                <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelDeadzone}" Style="{StaticResource SettingLabel}"/>
                                    <TextBlock x:Name="DeadzoneValueText" Text="20px" Grid.Column="1" 
                                               Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                </Grid>
                                <Slider x:Name="DeadzoneSlider" Minimum="5" Maximum="50" Value="20" 
                                        ValueChanged="DeadzoneSlider_ValueChanged"/>
                                <TextBlock Text="{DynamicResource DescDeadzone}" Style="{StaticResource SettingDescription}"/>
                                
                                <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelBreakSpeedLimit}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescBreakSpeedLimit}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="BreakSpeedLimitToggle" Grid.Column="1" Width="44" Height="24"
                                                          IsOnChanged="BreakSpeedLimitToggle_IsOnChanged"/>
