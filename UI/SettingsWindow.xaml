<Window x:Class="FlowWheel.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowWheel.UI.Controls"
        Title="{DynamicResource WindowTitle}" 
        Height="580" Width="780"
        ResizeMode="CanResize" 
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background}" FontFamily="Segoe UI"
        x:Name="MainWindow">
    
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Dark mode tide animation overlay -->
        <Border x:Name="DarkModeOverlay" Grid.ColumnSpan="2" 
                Background="{DynamicResource Brush.Background}" 
                Opacity="0" IsHitTestVisible="False"
                ClipToBounds="True">
            <Border.RenderTransform>
                <ScaleTransform x:Name="OverlayScale" ScaleX="0" ScaleY="0"/>
            </Border.RenderTransform>
            <Ellipse x:Name="OverlayCircle" Fill="{Binding Background, RelativeSource={RelativeSource AncestorType=Border}}"
                     Stretch="UniformToFill"/>
        </Border>
        
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="{DynamicResource Brush.Sidebar.Background}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Margin="16,16,16,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="M12,2 L12,22 M2,12 L22,12" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2.5" 
                              Width="22" Height="22" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="FlowWheel" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </StackPanel>
                    <TextBlock x:Name="VersionLabel" Text="v1.5.4" FontSize="11" 
                               Foreground="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Margin="8,4">
                    <RadioButton x:Name="NavGeneral" GroupName="Nav" Content="{DynamicResource NavGeneral}" 
                                 Tag="{StaticResource IconSettings}" IsChecked="True" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavBehavior" GroupName="Nav" Content="{DynamicResource NavBehavior}" 
                                 Tag="{StaticResource IconMouse}" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavFilter" GroupName="Nav" Content="{DynamicResource NavFilter}" 
                                 Tag="{StaticResource IconFilter}" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavShortcuts" GroupName="Nav" Content="{DynamicResource NavShortcuts}" 
                                 Tag="{StaticResource IconKeyboard}" Style="{StaticResource NavButtonStyle}"/>
                    <RadioButton x:Name="NavAbout" GroupName="Nav" Content="{DynamicResource NavAbout}" 
                                 Tag="{StaticResource IconInfo}" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
                
                <Border Grid.Row="2" Margin="12,0,12,12" Background="{DynamicResource Brush.Control.Background}" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LabelDarkMode}" FontSize="12" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        </StackPanel>
                        <controls:ToggleSwitch x:Name="DarkModeToggle" Grid.Column="1" Width="44" Height="24"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border x:Name="HeaderBorder" Grid.Row="0" Background="{DynamicResource Brush.Sidebar.Background}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="16,12">
                <TextBlock x:Name="PageTitle" Text="{DynamicResource NavGeneral}" 
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
            </Border>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                <Grid>
                    <StackPanel x:Name="PageGeneral" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionLanguage}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelLanguage}" Style="{StaticResource SettingLabel}"/>
                                    <ComboBox x:Name="LanguageCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}"
                                              SelectionChanged="LanguageCombo_SelectionChanged">
                                        <ComboBoxItem Content="English" Tag="en-US"/>
                                        <ComboBoxItem Content="简体中文" Tag="zh-CN"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionStatus}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckEnable}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescEnable}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="EnableToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckStartup}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescStartup}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="StartupToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageBehavior" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionTrigger}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckSyncScroll}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescSyncScroll}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="SyncToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource CheckReadingMode}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescReadingMode}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="ReadingModeToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionTriggerMode}" Style="{StaticResource SectionTitle}"/>
                                
                                <RadioButton x:Name="RadioClickToggle" GroupName="TriggerMode" 
                                             Content="{DynamicResource RadioClickToggle}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                                
                                <RadioButton x:Name="RadioHoldDrag" GroupName="TriggerMode" 
                                             Content="{DynamicResource RadioHoldDrag}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionTriggerKey}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelTriggerKey}" Style="{StaticResource SettingLabel}"/>
                                    <ComboBox x:Name="TriggerKeyCombo" Grid.Column="1" Style="{StaticResource ModernComboBox}"
                                              SelectionChanged="TriggerKeyCombo_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource KeyMiddleMouse}" Tag="MiddleMouse"/>
                                        <ComboBoxItem Content="{DynamicResource KeyXButton1}" Tag="XButton1"/>
                                        <ComboBoxItem Content="{DynamicResource KeyXButton2}" Tag="XButton2"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionSensitivity}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelScrollSpeed}" Style="{StaticResource SettingLabel}"/>
                                    <TextBlock x:Name="SpeedValueText" Text="0.8x" Grid.Column="1" 
                                               Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                </Grid>
                                <Slider x:Name="SpeedSlider" Minimum="0.1" Maximum="3.0" Value="0.8" 
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                        ValueChanged="SpeedSlider_ValueChanged"/>
                                
                                <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelDeadzone}" Style="{StaticResource SettingLabel}"/>
                                    <TextBlock x:Name="DeadzoneValueText" Text="20px" Grid.Column="1" 
                                               Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                </Grid>
                                <Slider x:Name="DeadzoneSlider" Minimum="5" Maximum="50" Value="20" 
                                        ValueChanged="DeadzoneSlider_ValueChanged"/>
                                <TextBlock Text="{DynamicResource DescDeadzone}" Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageFilter" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionFilterMode}" Style="{StaticResource SectionTitle}"/>
                                
                                <RadioButton x:Name="RadioBlacklist" GroupName="FilterMode" 
                                             Content="{DynamicResource RadioBlacklist}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                                
                                <RadioButton x:Name="RadioWhitelist" GroupName="FilterMode" 
                                             Content="{DynamicResource RadioWhitelist}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                                
                                <TextBlock x:Name="FilterModeHelpText" Text="Processes in this list will be ignored." 
                                           Style="{StaticResource SettingDescription}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionAppList}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BlacklistInput" Style="{StaticResource ModernTextBox}" 
                                             Margin="0,0,6,0" ToolTip="Enter process name (e.g. notepad)"/>
                                    <Button Grid.Column="1" Content="..." 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="0,0,6,0"
                                            Click="BrowseApp_Click" ToolTip="Browse"/>
                                    <Button Grid.Column="2" Content="+" 
                                            Style="{StaticResource ModernButton}" Padding="10,6"
                                            Click="AddBlacklist_Click" ToolTip="Add"/>
                                </Grid>
                                
                                <ListBox x:Name="BlacklistList" Height="180" Style="{StaticResource ModernListBox}"
                                         AllowDrop="True" Drop="BlacklistList_Drop">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                <Button Grid.Column="1" Content="×" 
                                                        Style="{StaticResource ModernButton}" Padding="6,4" 
                                                        Background="Transparent" Foreground="#E74C3C"
                                                        Click="RemoveBlacklist_Click" Tag="{Binding ProcessName}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="Tip: Drag &amp; drop .exe files here" Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageShortcuts" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionHotkey}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelToggleShortcut}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescToggleShortcut}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="HotkeyInput" Style="{StaticResource ModernTextBox}" 
                                             IsReadOnly="True" PreviewKeyDown="HotkeyInput_PreviewKeyDown"
                                             GotFocus="HotkeyInput_GotFocus" LostFocus="HotkeyInput_LostFocus"
                                             Text="Click to set hotkey..."/>
                                    <Button Grid.Column="1" Content="×" 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="6,0,0,0"
                                            Click="ClearHotkey_Click" ToolTip="Clear"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="M12,2 L12,22 M2,12 L22,12" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2.5" 
                                      Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,12"/>
                                <TextBlock Text="FlowWheel" FontSize="22" FontWeight="Bold" 
                                           Foreground="{DynamicResource Brush.Text.Primary}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="VersionText" Text="Version 1.5.4" FontSize="13" 
                                           Foreground="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock Text="{DynamicResource AppDescription}" FontSize="12" 
                                           Foreground="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" 
                                           Margin="0,8,0,20" TextWrapping="Wrap" TextAlignment="Center"/>
                                
                                <Button Content="{DynamicResource BtnCheckUpdate}" Style="{StaticResource ModernButton}"
                                        Click="CheckUpdate_Click" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionLinks}" Style="{StaticResource SectionTitle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="OpenGitHub_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconGitHub}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                            <TextBlock Text="GitHub"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource ModernButton}" BorderThickness="1" BorderBrush="{DynamicResource Brush.Accent}" Background="Transparent" Foreground="{DynamicResource Brush.Accent}" Click="OpenLicense_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconLicense}" Fill="{DynamicResource Brush.Accent}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource BtnLicense}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource SectionSupport}" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DescSupport}" Style="{StaticResource SettingDescription}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <Image Source="pack://application:,,,/Assets/alipay_qr.png" Width="120" Height="120" Stretch="Uniform"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>