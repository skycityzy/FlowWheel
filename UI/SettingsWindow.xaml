                                            TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                            ValueChanged="InertiaSlider_ValueChanged"/>
                                    
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource LabelResponseTime}" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="{DynamicResource DescResponseTime}" Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ResponseTimeValueText" Text="40ms" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="ResponseTimeSlider" Minimum="10" Maximum="200" Value="40" 
                                            TickFrequency="5" IsSnapToTickEnabled="True" 
                                            ValueChanged="ResponseTimeSlider_ValueChanged"/>
                                    
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource LabelAxisLock}" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="{DynamicResource DescAxisLock}" Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="AxisLockValueText" Text="1.8" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="AxisLockSlider" Minimum="1.0" Maximum="5.0" Value="1.8" 
                                            TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                            ValueChanged="AxisLockSlider_ValueChanged"/>
                                    
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource LabelSoftStart}" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="{DynamicResource DescSoftStart}" Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="SoftStartValueText" Text="12px" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="SoftStartSlider" Minimum="0" Maximum="50" Value="12" 
                                            TickFrequency="1" IsSnapToTickEnabled="True" 
                                            ValueChanged="SoftStartSlider_ValueChanged"/>
                                    
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource LabelMaxScrollSpeed}" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="{DynamicResource DescMaxScrollSpeed}" Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="MaxScrollSpeedValueText" Text="1500 px/s" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
                                    <Slider x:Name="MaxScrollSpeedSlider" Minimum="500" Maximum="2000" Value="1500" 
                                            TickFrequency="100" IsSnapToTickEnabled="True" 
                                            ValueChanged="MaxScrollSpeedSlider_ValueChanged"/>
                                    
                                    <Button Content="{DynamicResource BtnResetAllDefaults}" 
                                            Style="{StaticResource ModernButton}" Margin="0,16,0,0"
                                            Click="ResetAllDefaults_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionCustomIcon}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelCustomIcon}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescCustomIcon}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CustomIconPathInput" Style="{StaticResource ModernTextBox}" 
                                             IsReadOnly="True" ToolTip="{DynamicResource DescCustomIcon}"/>
                                    <Button Grid.Column="1" Content="..." 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="6,0,6,0"
                                            Click="BrowseIcon_Click" ToolTip="{DynamicResource BtnBrowse}"/>
                                    <Button Grid.Column="2" Content="×" 
                                            Style="{StaticResource ModernButton}" Padding="10,6"
                                            Click="ClearIcon_Click" ToolTip="{DynamicResource BtnClear}"/>
                                </Grid>
                                
                                <Grid Style="{StaticResource SettingRow}" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource LabelIconSize}" Style="{StaticResource SettingLabel}"/>
                                    <TextBlock x:Name="IconSizeValueText" Text="48px" Grid.Column="1" 
                                               Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                </Grid>
                                <Slider x:Name="IconSizeSlider" Minimum="24" Maximum="96" Value="48" 
                                        TickFrequency="1" IsSnapToTickEnabled="True" 
                                        ValueChanged="IconSizeSlider_ValueChanged"/>
                                <TextBlock Text="{DynamicResource DescIconSize}" Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageFilter" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionFilterMode}" Style="{StaticResource SectionTitle}"/>
                                
                                <RadioButton x:Name="RadioBlacklist" GroupName="FilterMode" 
                                             Content="{DynamicResource RadioBlacklist}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                                
                                <RadioButton x:Name="RadioWhitelist" GroupName="FilterMode" 
                                             Content="{DynamicResource RadioWhitelist}" 
                                             Style="{StaticResource SettingRadioStyle}"/>
                                
                                <TextBlock x:Name="FilterModeHelpText" Text="Processes in this list will be ignored." 
                                           Style="{StaticResource SettingDescription}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionAppList}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BlacklistInput" Style="{StaticResource ModernTextBox}" 
                                             Margin="0,0,6,0" ToolTip="Enter process name (e.g. notepad)"/>
                                    <Button Grid.Column="1" Content="..." 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="0,0,6,0"
                                            Click="BrowseApp_Click" ToolTip="Browse"/>
                                    <Button Grid.Column="2" Content="+" 
                                            Style="{StaticResource ModernButton}" Padding="10,6"
                                            Click="AddBlacklist_Click" ToolTip="Add"/>
                                </Grid>
                                
                                <ListBox x:Name="BlacklistList" Height="180" Style="{StaticResource ModernListBox}"
                                         AllowDrop="True" Drop="BlacklistList_Drop">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                <Button Grid.Column="1" Content="×" 
                                                        Style="{StaticResource ModernButton}" Padding="6,4" 
                                                        Background="Transparent" Foreground="#E74C3C"
                                                        Click="RemoveBlacklist_Click" Tag="{Binding ProcessName}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="Tip: Drag &amp; drop .exe files here" Style="{StaticResource SettingDescription}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageShortcuts" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionHotkey}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelAppStatus}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescAppStatus}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                    <controls:ToggleSwitch x:Name="AppStatusToggle" Grid.Column="1" Width="44" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionTriggerKey}" Style="{StaticResource SectionTitle}"/>
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelTriggerKey}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescTriggerKey}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TriggerKeyInput" Style="{StaticResource ModernTextBox}"
                                             TextChanged="TriggerKeyInput_TextChanged"
                                             ToolTip="{DynamicResource DescTriggerKey}"/>
                                    <Button x:Name="BtnListen" Grid.Column="1" Content="{DynamicResource BtnListen}" 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="6,0,0,0"
                                            Click="BtnListen_Click" ToolTip="{DynamicResource BtnListenTip}"/>
                                    <Button Grid.Column="2" Content="{DynamicResource BtnPreset}" 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="6,0,0,0"
                                            Click="TriggerKeyPreset_Click" ToolTip="{DynamicResource BtnPresetTip}"/>
                                </Grid>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button Content="{DynamicResource KeyMiddleMouse}" Style="{StaticResource ModernButton}" Padding="8,4" Margin="0,0,4,0"
                                            FontSize="11" Click="TriggerKeyPreset_Select" Tag="MiddleMouse"/>
                                    <Button Content="Alt+Middle" Style="{StaticResource ModernButton}" Padding="8,4" Margin="0,0,4,0"
                                            FontSize="11" Click="TriggerKeyPreset_Select" Tag="Alt+MiddleMouse"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionReadingModeHotkey}" Style="{StaticResource SectionTitle}"/>
                                
                                <Grid Style="{StaticResource SettingRow}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LabelReadingModeHotkey}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="{DynamicResource DescReadingModeHotkey}" Style="{StaticResource SettingDescription}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ReadingModeHotkeyInput" Style="{StaticResource ModernTextBox}"
                                             TextChanged="ReadingModeHotkeyInput_TextChanged"
                                             ToolTip="{DynamicResource DescReadingModeHotkey}"/>
                                    <Button x:Name="BtnReadingModeListen" Grid.Column="1" Content="{DynamicResource BtnListen}" 
                                            Style="{StaticResource ModernButton}" Padding="10,6" Margin="6,0,0,0"
                                            Click="BtnReadingModeListen_Click" ToolTip="{DynamicResource BtnListenTip}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="0"/>
                        </StackPanel.RenderTransform>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Path Data="{StaticResource IconFlowWheel}" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.5" Fill="{DynamicResource Brush.Accent}" Opacity="0.85"
                                      Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,12">
                                    <Path.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.4" Color="{DynamicResource Color.Accent}"/>
                                    </Path.Effect>
                                </Path>
                                <TextBlock Text="FlowWheel" FontSize="22" FontWeight="Bold" 
                                           Foreground="{DynamicResource Brush.Text.Primary}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="VersionText" Text="Version 1.6.0" FontSize="13" 
                                           Foreground="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock Text="{DynamicResource AppDescription}" FontSize="12" 
                                           Foreground="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" 
                                           Margin="0,8,0,20" TextWrapping="Wrap" TextAlignment="Center"/>
                                
                                <Button Content="{DynamicResource BtnCheckUpdate}" Style="{StaticResource ModernButton}"
                                        Click="CheckUpdate_Click" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionLinks}" Style="{StaticResource SectionTitle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="OpenGitHub_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconGitHub}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                            <TextBlock Text="GitHub"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource ModernButton}" BorderThickness="1" BorderBrush="{DynamicResource Brush.Accent}" Background="Transparent" Foreground="{DynamicResource Brush.Accent}" Click="OpenLicense_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconLicense}" Fill="{DynamicResource Brush.Accent}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource BtnLicense}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{DynamicResource SectionSupport}" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DescSupport}" Style="{StaticResource SettingDescription}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <Image Source="pack://application:,,,/Assets/alipay_qr.png" Width="120" Height="120" Stretch="Uniform"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>