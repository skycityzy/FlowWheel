                                    </Grid>
                                    <Slider x:Name="FrictionSlider" Minimum="1.0" Maximum="20.0" Value="5.0" 
                                            TickFrequency="0.5" IsSnapToTickEnabled="True" 
                                            ValueChanged="FrictionSlider_ValueChanged"/>
                                    
                                    <Grid Style="{StaticResource SettingRow}" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource LabelInertia}" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="{DynamicResource DescInertia}" Style="{StaticResource SettingDescription}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="InertiaValueText" Text="1.0x" Grid.Column="1" 
                                                   Style="{StaticResource SettingLabel}" Foreground="{DynamicResource Brush.Accent}"/>
                                    </Grid>
