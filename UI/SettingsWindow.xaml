                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LabelLogBase}" Style="{StaticResource SettingLabel}"/>
                                        <TextBlock x:Name="LogBaseValueText" Text="2.0" Grid.Column="1" 
