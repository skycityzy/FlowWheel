                                </Grid>
                                
                                <StackPanel x:Name="AdvancedParamsPanel" Visibility="Collapsed">
                                    <Grid Style="{StaticResource SettingRow}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource LabelFriction}" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="{DynamicResource DescFriction}" Style="{StaticResource SettingDescription}"/>
