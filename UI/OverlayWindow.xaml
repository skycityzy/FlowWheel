<Window x:Class="FlowWheel.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlowWheelOverlay" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="{x:Null}"
        Topmost="True" 
        ShowInTaskbar="False"
        IsHitTestVisible="False">
    
    <Grid>
        <Canvas x:Name="MainCanvas">
            <Grid x:Name="Anchor" Visibility="Collapsed">
                <!-- Custom Image -->
                <Image x:Name="CustomAnchorImage" Stretch="Uniform" Visibility="Collapsed"/>
                
                <!-- Default Wheel Icon - Modernized -->
                <Canvas x:Name="WheelIndicatorCanvas">
                    <Grid x:Name="WheelIndicator">
                        <!-- Outer Glow Ring (soft halo) -->
                        <Ellipse x:Name="OuterGlow" 
                                 StrokeThickness="0"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Opacity="0.25">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource Color.Accent}" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        
                        <!-- Outer Ring - Gradient stroke with glow -->
                        <Ellipse x:Name="OuterRing" 
                                 StrokeThickness="2"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Stroke>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="{DynamicResource Color.Accent}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource Color.Accent}" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#CC1A1A2E" Offset="0"/>
                                    <GradientStop Color="#E616161E" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="{DynamicResource Color.Accent}" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        
                        <!-- Inner Ring -->
                        <Ellipse x:Name="InnerRing"
                                 Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.5" Opacity="0.5"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        
                        <!-- Center Dot with glow -->
                        <Ellipse x:Name="CenterDot" Fill="{DynamicResource Brush.Accent}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="{DynamicResource Color.Accent}" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        
                        <!-- Spinning Wheel Lines -->
                        <Grid x:Name="SpinningWheel">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="WheelRotate" Angle="0"/>
                            </Grid.RenderTransform>
                            <!-- Up -->
                            <Path x:Name="LineUp" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2" Opacity="0.7"/>
                            <!-- Down -->
                            <Path x:Name="LineDown" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2" Opacity="0.7"/>
                            <!-- Left -->
                            <Path x:Name="LineLeft" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2" Opacity="0.7"/>
                            <!-- Right -->
                            <Path x:Name="LineRight" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="2" Opacity="0.7"/>
                        </Grid>
                        
                        <!-- Breathing Animation Layer - subtle opacity pulse when idle -->
                        <Ellipse x:Name="BreathingRing"
                                 Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1" Opacity="0"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Width="44" Height="44"/>
                        
                        <!-- Reading Mode Icon -->
                        <Path x:Name="ReadingIcon" Data="M10,5 L20,15 L10,25 Z" 
                              Fill="#00DD44" Stretch="Uniform"
                              Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path.Effect>
                                <DropShadowEffect Color="#00DD44" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                            </Path.Effect>
                        </Path>
                    </Grid>
                    
                    <!-- Reading Speed Display -->
                    <TextBlock x:Name="ReadingSpeedText" 
                               Text="30 px/s" 
                               Foreground="#00DD44" 
                               FontSize="11" FontWeight="SemiBold"
                               Visibility="Collapsed"
                               Canvas.Left="0" Canvas.Top="0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00DD44" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    
                    <!-- Break Speed Limit Indicator -->
                    <Border x:Name="BreakSpeedIndicator" 
                            CornerRadius="4" Padding="4,2"
                            Background="#CCFF4444" 
                            Visibility="Collapsed"
                            Canvas.Left="0" Canvas.Top="0"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BreakSpeedScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <TextBlock Text="⚡ UNLIMITED" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    
                    <!-- Direction Arrows - Filled triangles for modern look -->
                    <Path x:Name="ArrowUp" Data="M0,10 L6,0 L12,10 Z" Fill="White" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="0.5"
                          Width="12" Height="11" Visibility="Collapsed" Opacity="0.9">
                        <Path.Effect>
                            <DropShadowEffect Color="{DynamicResource Color.Accent}" BlurRadius="4" ShadowDepth="0" Opacity="0.7"/>
                        </Path.Effect>
                    </Path>
                    <Path x:Name="ArrowDown" Data="M0,0 L6,10 L12,0 Z" Fill="White" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="0.5"
                          Width="12" Height="11" Visibility="Collapsed" Opacity="0.9">
                        <Path.Effect>
                            <DropShadowEffect Color="{DynamicResource Color.Accent}" BlurRadius="4" ShadowDepth="0" Opacity="0.7"/>
                        </Path.Effect>
                    </Path>
                    <Path x:Name="ArrowLeft" Data="M10,0 L0,6 L10,12 Z" Fill="White" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="0.5"
                          Width="11" Height="12" Visibility="Collapsed" Opacity="0.9">
                        <Path.Effect>
                            <DropShadowEffect Color="{DynamicResource Color.Accent}" BlurRadius="4" ShadowDepth="0" Opacity="0.7"/>
                        </Path.Effect>
                    </Path>
                    <Path x:Name="ArrowRight" Data="M0,0 L10,6 L0,12 Z" Fill="White" Stroke="{DynamicResource Brush.Accent}" StrokeThickness="0.5"
                          Width="11" Height="12" Visibility="Collapsed" Opacity="0.9">
                        <Path.Effect>
                            <DropShadowEffect Color="{DynamicResource Color.Accent}" BlurRadius="4" ShadowDepth="0" Opacity="0.7"/>
                        </Path.Effect>
                    </Path>
                </Canvas>
            </Grid>
        </Canvas>
    </Grid>
</Window>
